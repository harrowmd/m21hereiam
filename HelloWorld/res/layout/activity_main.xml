<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.example.helloworld.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Date: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
            <TextView android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
            <TextView android:id="@+id/tv_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Battery: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
            <TextView android:id="@+id/tv_satellites"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Satellites: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView android:id="@+id/tv_lat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lat: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
            <TextView android:id="@+id/tv_lon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lon: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
            <TextView android:id="@+id/tv_alt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alt: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
            <TextView android:id="@+id/tv_accuracy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accuracy: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
