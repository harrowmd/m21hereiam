<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.example.m21hereiam.MapView
        android:id="@+id/map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <Button
        android:id="@+id/btn_cancel_alert"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16dp"
        android:background="#CCDD0000"
        android:text="Cancel Alert"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="#CC333333"
        android:text="&#9881;"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:padding="0dp" />

    <Button
        android:id="@+id/btn_recentre"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="110dp"
        android:layout_marginEnd="16dp"
        android:background="#FF2979FF"
        android:text="&#8982;"
        android:textColor="#FFFFFF"
        android:textSize="22sp"
        android:padding="0dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
            <TextView android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
            <TextView android:id="@+id/tv_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Battery: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
            <TextView android:id="@+id/tv_satellites"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Satellites: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView android:id="@+id/tv_lat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lat: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
            <TextView android:id="@+id/tv_lon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lon: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
            <TextView android:id="@+id/tv_alt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alt: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
            <TextView android:id="@+id/tv_accuracy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accuracy: --"
                android:textColor="#FFFFFF"
                android:textSize="13sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="What3Words"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:gravity="end" />
            <TextView android:id="@+id/tv_w3w_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:gravity="end" />
            <TextView android:id="@+id/tv_w3w_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:gravity="end" />
            <TextView android:id="@+id/tv_w3w_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:gravity="end" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
